# ============================================================
# DebugGPT - .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# IDEs
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Python Build
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ------------------------------------------------------------
# Testing
# ------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ------------------------------------------------------------
# Type Checking
# ------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/

# ------------------------------------------------------------
# Ruff / Black
# ------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo

# ------------------------------------------------------------
# ChromaDB Runtime Data
# ------------------------------------------------------------
chromadb/
!chromadb/.gitkeep

# ------------------------------------------------------------
# AI Models
# ------------------------------------------------------------
models/
!models/.gitkeep

# ------------------------------------------------------------
# Hugging Face Cache
# ------------------------------------------------------------
.cache/
.huggingface/
hf_cache/

# ------------------------------------------------------------
# Training Outputs
# ------------------------------------------------------------
outputs/
checkpoints/
runs/
trainer_state.json

# ------------------------------------------------------------
# TensorBoard
# ------------------------------------------------------------
events.out.tfevents.*

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
*.pid

# ------------------------------------------------------------
# Streamlit
# ------------------------------------------------------------
.streamlit/secrets.toml

# ------------------------------------------------------------
# Uploaded User Files
# ------------------------------------------------------------
uploads/
temp/
cache/

# ------------------------------------------------------------
# Dataset Artifacts
# (Keep only if datasets will be regenerated)
# ------------------------------------------------------------
datasets/processed/
datasets/cache/

# ------------------------------------------------------------
# Compiled Files
# ------------------------------------------------------------
*.exe
*.dll
*.o
*.obj

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.sqlite3
*.db